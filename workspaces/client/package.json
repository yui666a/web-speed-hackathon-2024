{
  "name": "@wsh-2024/client",
  "private": true,
  "scripts": {
    "build": "pnpm run build:clean && pnpm run build:vite && pnpm run build:sw && pnpm run build:copy",
    "build:clean": "rm -rf ./dist",
    "build:vite": "vite build",
    "build:sw": "vite build --config vite.sw.config.ts",
    "build:copy": "cp -r ./assets ./dist/assets"
  },
  "dependencies": {
    "@jsquash/jxl": "1.1.0",
    "@wsh-2024/admin": "workspace:*",
    "@wsh-2024/app": "workspace:*",
    "fzstd": "0.1.0",
    "jimp": "0.22.12",
    "p-queue": "8.0.1",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-router-dom": "6.18.0",
    "swr": "2.2.4"
  },
  "devDependencies": {
    "@node-kit/pnpm-workspace-root": "3.2.0",
    "@types/jimp": "0.2.28",
    "@types/react": "18.2.0",
    "@types/react-dom": "18.2.1",
    "@types/serviceworker": "0.0.83",
    "@vitejs/plugin-react": "4.2.1",
    "pkg-dir": "5.0.0",
    "vite": "5.4.14",
    "vite-plugin-node-polyfills": "0.21.0"
  }
}
